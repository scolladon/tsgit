{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/scolladon/tsgit/scripts/mutation-budgets-schema.json",
  "title": "tsgit mutation budgets",
  "description": "Per-bucket mutation-score budgets enforced by scripts/check-mutation-budgets.ts. See docs/design/phase-19-1-mutation-pyramid.md.",
  "type": "object",
  "required": ["buckets"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "buckets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/bucket" }
    }
  },
  "$defs": {
    "bucket": {
      "type": "object",
      "required": ["name", "globs", "thresholds"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "enum": ["domain", "application", "adapters", "infra"]
        },
        "globs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "thresholds": {
          "type": "object",
          "required": ["high", "low", "break"],
          "additionalProperties": false,
          "properties": {
            "high": { "type": "number", "minimum": 0, "maximum": 100 },
            "low": { "type": "number", "minimum": 0, "maximum": 100 },
            "break": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        }
      }
    }
  }
}
