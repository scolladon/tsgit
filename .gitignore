# Dependencies
node_modules/

# Build output
dist/

# Coverage
coverage/

# Mutation testing
.stryker-tmp/

# Reports — directory contents are gitignored except the typedoc JSON snapshot,
# which is committed as the drift baseline (Phase 18.3, ADR-098). git won't
# re-include files under a wholly-excluded parent, so we exclude entries
# instead of the directory itself.
reports/*
!reports/api.json

# Lychee local cache (.lycheecache) — populated by `npm run check:doc-links`.
.lycheecache

# Wireit cache
.wireit/

# TypeScript build info
*.tsbuildinfo

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Playwright
test-results/
playwright-report/

# Browser parity bundle (built by `npm run build:parity`)
test/browser/parity-scenarios.bundle.js
test/browser/parity-scenarios.bundle.js.map

# Runtime-parity matrix caches (Phase 19.8)
test/runtime-parity/workers/.wrangler/
test/runtime-parity/workers/.mf/

# MegaLinter
megalinter-reports/

# Environment
.env
.env.local
.env.*.local
