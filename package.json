{
  "name": "@scolladon/tsgit",
  "version": "0.9.0",
  "description": "Lightning-fast git, pure TypeScript, everywhere.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.3.0"
  },
  "sideEffects": false,
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "node": {
        "import": {
          "types": "./dist/types/index.node.d.ts",
          "default": "./dist/esm/index.node.js"
        },
        "require": {
          "types": "./dist/types/index.node.d.cts",
          "default": "./dist/cjs/index.node.cjs"
        }
      },
      "browser": {
        "import": {
          "types": "./dist/types/index.browser.d.ts",
          "default": "./dist/esm/index.browser.js"
        }
      },
      "default": {
        "import": {
          "types": "./dist/types/index.default.d.ts",
          "default": "./dist/esm/index.default.js"
        },
        "require": {
          "types": "./dist/types/index.default.d.cts",
          "default": "./dist/cjs/index.default.cjs"
        }
      }
    },
    "./auto/node": {
      "import": {
        "types": "./dist/types/index.node.d.ts",
        "default": "./dist/esm/index.node.js"
      },
      "require": {
        "types": "./dist/types/index.node.d.cts",
        "default": "./dist/cjs/index.node.cjs"
      }
    },
    "./auto/browser": {
      "import": {
        "types": "./dist/types/index.browser.d.ts",
        "default": "./dist/esm/index.browser.js"
      },
      "require": {
        "types": "./dist/types/index.browser.d.cts",
        "default": "./dist/cjs/index.browser.cjs"
      }
    },
    "./auto/memory": {
      "import": {
        "types": "./dist/types/index.default.d.ts",
        "default": "./dist/esm/index.default.js"
      },
      "require": {
        "types": "./dist/types/index.default.d.cts",
        "default": "./dist/cjs/index.default.cjs"
      }
    },
    "./primitives": {
      "import": {
        "types": "./dist/types/primitives/index.d.ts",
        "default": "./dist/esm/primitives/index.js"
      },
      "require": {
        "types": "./dist/types/primitives/index.d.cts",
        "default": "./dist/cjs/primitives/index.cjs"
      }
    },
    "./commands/*": {
      "import": {
        "types": "./dist/types/commands/*.d.ts",
        "default": "./dist/esm/commands/*.js"
      },
      "require": {
        "types": "./dist/types/commands/*.d.cts",
        "default": "./dist/cjs/commands/*.cjs"
      }
    },
    "./operators": {
      "import": {
        "types": "./dist/types/operators/index.d.ts",
        "default": "./dist/esm/operators/index.js"
      },
      "require": {
        "types": "./dist/types/operators/index.d.cts",
        "default": "./dist/cjs/operators/index.cjs"
      }
    },
    "./transport": {
      "import": {
        "types": "./dist/types/transport/index.d.ts",
        "default": "./dist/esm/transport/index.js"
      },
      "require": {
        "types": "./dist/types/transport/index.d.cts",
        "default": "./dist/cjs/transport/index.cjs"
      }
    },
    "./adapters/node": {
      "import": {
        "types": "./dist/types/adapters/node/index.d.ts",
        "default": "./dist/esm/adapters/node/index.js"
      },
      "require": {
        "types": "./dist/types/adapters/node/index.d.cts",
        "default": "./dist/cjs/adapters/node/index.cjs"
      }
    },
    "./adapters/browser": {
      "import": {
        "types": "./dist/types/adapters/browser/index.d.ts",
        "default": "./dist/esm/adapters/browser/index.js"
      },
      "require": {
        "types": "./dist/types/adapters/browser/index.d.cts",
        "default": "./dist/cjs/adapters/browser/index.cjs"
      }
    },
    "./adapters/memory": {
      "import": {
        "types": "./dist/types/adapters/memory/index.d.ts",
        "default": "./dist/esm/adapters/memory/index.js"
      },
      "require": {
        "types": "./dist/types/adapters/memory/index.d.cts",
        "default": "./dist/cjs/adapters/memory/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "wireit",
    "check": "wireit",
    "check:fix": "wireit",
    "check:types": "wireit",
    "check:dead-code": "wireit",
    "check:duplicates": "wireit",
    "check:filesystem": "wireit",
    "check:deps": "wireit",
    "test": "wireit",
    "test:unit": "wireit",
    "test:integration": "wireit",
    "test:e2e": "wireit",
    "test:coverage": "wireit",
    "test:mutation": "wireit",
    "test:mutation:incremental": "wireit",
    "test:bench": "wireit",
    "bench:summary": "wireit",
    "docs": "wireit",
    "docs:check": "wireit",
    "verify:tarball": "wireit",
    "check:size": "wireit",
    "check:exports": "wireit",
    "check:security": "wireit",
    "check:architecture": "wireit",
    "check:spelling": "wireit",
    "validate": "wireit"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "build:js"
      ]
    },
    "build:js": {
      "command": "rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript",
      "dependencies": [
        "check:types"
      ],
      "files": [
        "src/**/*.ts",
        "rollup.config.ts",
        "tsconfig.build.json"
      ],
      "output": [
        "dist/esm/**",
        "dist/cjs/**",
        "dist/types/**"
      ],
      "clean": "if-file-deleted"
    },
    "check": {
      "command": "biome check .",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "biome.json"
      ],
      "output": []
    },
    "check:fix": {
      "command": "biome check --write .",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "biome.json"
      ],
      "output": []
    },
    "check:types": {
      "command": "tsc --noEmit",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "tsconfig.json"
      ],
      "output": []
    },
    "check:dead-code": {
      "command": "knip",
      "files": [
        "src/**/*.ts",
        "knip.json",
        "package.json"
      ],
      "output": []
    },
    "check:duplicates": {
      "command": "jscpd src/",
      "files": [
        "src/**/*.ts",
        ".jscpd.json"
      ],
      "output": []
    },
    "check:filesystem": {
      "command": "ls-lint",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        ".ls-lint.yml"
      ],
      "output": []
    },
    "check:deps": {
      "command": "npm outdated || true",
      "files": [
        "package.json"
      ],
      "output": []
    },
    "test": {
      "command": "vitest run",
      "dependencies": [
        "check:types"
      ],
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "vitest.config.ts"
      ],
      "output": []
    },
    "test:unit": {
      "command": "vitest run --project unit",
      "dependencies": [
        "check:types"
      ],
      "files": [
        "src/**/*.ts",
        "test/unit/**/*.ts",
        "vitest.config.ts"
      ],
      "output": []
    },
    "test:integration": {
      "command": "vitest run --project integration",
      "dependencies": [
        "check:types"
      ],
      "files": [
        "src/**/*.ts",
        "test/integration/**/*.ts",
        "vitest.config.ts"
      ],
      "output": []
    },
    "test:e2e": {
      "command": "npx playwright test",
      "dependencies": [
        "build"
      ],
      "files": [
        "test/browser/**/*.ts",
        "test/browser/**/*.mjs",
        "test/browser/index.html",
        "playwright.config.ts"
      ],
      "output": [
        "reports/playwright/**"
      ]
    },
    "test:coverage": {
      "command": "vitest run --coverage",
      "dependencies": [
        "check:types"
      ],
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "vitest.config.ts"
      ],
      "output": [
        "coverage/**"
      ]
    },
    "test:mutation": {
      "command": "stryker run",
      "dependencies": [
        "test:unit"
      ],
      "files": [
        "src/**/*.ts",
        "test/unit/**/*.ts",
        "stryker.config.json",
        "vitest.config.ts"
      ],
      "output": [
        "reports/mutation/**"
      ]
    },
    "test:mutation:incremental": {
      "command": "stryker run --incremental",
      "dependencies": [
        "test:unit"
      ],
      "files": [
        "src/**/*.ts",
        "test/unit/**/*.ts",
        "stryker.config.json",
        "vitest.config.ts"
      ],
      "output": [
        "reports/mutation/**"
      ]
    },
    "test:bench": {
      "command": "vitest bench --run --config vitest.bench.config.ts",
      "dependencies": [
        "check:types"
      ],
      "files": [
        "src/**/*.ts",
        "test/bench/**/*.ts",
        "vitest.bench.config.ts"
      ],
      "output": [
        "reports/benchmarks/raw.json"
      ]
    },
    "bench:summary": {
      "command": "node --experimental-strip-types scripts/bench-summarize.ts",
      "dependencies": [
        "test:bench"
      ],
      "files": [
        "scripts/bench-summarize.ts",
        "reports/benchmarks/raw.json"
      ],
      "output": [
        "reports/benchmarks/summary.md"
      ]
    },
    "docs": {
      "command": "typedoc",
      "files": [
        "src/**/*.ts",
        "typedoc.json",
        "tsconfig.build.json",
        "README.md"
      ],
      "output": [
        "reports/api/**"
      ]
    },
    "docs:check": {
      "command": "typedoc --emit none",
      "files": [
        "src/**/*.ts",
        "typedoc.json",
        "tsconfig.build.json",
        "README.md"
      ],
      "output": []
    },
    "verify:tarball": {
      "command": "bash scripts/verify-tarball.sh",
      "dependencies": [
        "build"
      ],
      "files": [
        "scripts/verify-tarball.sh",
        "dist/**",
        "package.json",
        "LICENSE",
        "README.md"
      ],
      "output": []
    },
    "check:size": {
      "command": "size-limit",
      "dependencies": [
        "build"
      ],
      "files": [
        "dist/**",
        ".size-limit.json"
      ],
      "output": []
    },
    "check:exports": {
      "command": "attw --pack . --profile node16",
      "dependencies": [
        "build"
      ],
      "files": [
        "dist/**",
        "package.json"
      ],
      "output": []
    },
    "check:security": {
      "command": "npm audit --audit-level=high || true",
      "files": [
        "package-lock.json"
      ],
      "output": []
    },
    "check:architecture": {
      "command": "depcruise src/ --config .dependency-cruiser.cjs",
      "files": [
        "src/**/*.ts",
        ".dependency-cruiser.cjs"
      ],
      "output": []
    },
    "check:spelling": {
      "command": "cspell \"src/**/*.ts\" \"test/**/*.ts\" \"docs/**/*.md\" \"*.md\"",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "docs/**/*.md",
        "*.md",
        "cspell.json"
      ],
      "output": []
    },
    "validate": {
      "dependencies": [
        "check",
        "check:types",
        "check:dead-code",
        "check:duplicates",
        "check:filesystem",
        "check:architecture",
        "check:spelling",
        "check:deps",
        "check:size",
        "check:exports",
        "check:security",
        "test:coverage",
        "test:integration"
      ]
    }
  },
  "lint-staged": {
    "*.ts": [
      "biome check --write",
      "vitest related --run"
    ]
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.11",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@ls-lint/ls-lint": "2.3.1",
    "@playwright/test": "1.59.1",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@size-limit/file": "12.1.0",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/node": "22.19.17",
    "@vitest/coverage-v8": "4.1.4",
    "cspell": "10.0.0",
    "dependency-cruiser": "17.3.10",
    "fast-check": "4.6.0",
    "husky": "9.1.7",
    "isomorphic-git": "1.38.0",
    "jscpd": "4.0.9",
    "knip": "6.4.1",
    "lint-staged": "16.4.0",
    "rollup": "4.60.1",
    "rollup-plugin-dts": "6.4.1",
    "rollup-plugin-visualizer": "7.0.1",
    "size-limit": "12.1.0",
    "typedoc": "0.28.19",
    "typescript": "6.0.2",
    "vitest": "4.1.4",
    "wireit": "0.14.12"
  }
}
